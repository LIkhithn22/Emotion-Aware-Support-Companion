{
  "name": "emotion-aware-support-companion",
  "version": "0.1.0",
  "private": true,
  "description": "Emotion-Aware Support Companion — CISC 699 Capstone Project",
  "workspaces": [
    "packages/frontend",
    "packages/backend",
    "packages/tests"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=packages/backend",
