# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://easc_user:easc_password@localhost:5432/easc_dev"
TEST_DATABASE_URL="postgresql://easc_user:easc_password@localhost:5432/easc_test"

# ─── Backend Server ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_before_production
JWT_EXPIRES_IN=7d

# ─── Emotion Analysis ────────────────────────────────────────────────────────
# Confidence threshold below which UC05 RequestClarification is triggered
EMOTION_CONFIDENCE_THRESHOLD=0.60

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001/api/v1
